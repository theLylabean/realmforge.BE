// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  email        String    @unique
  password     String
  name         String?
  habits       Habit[]
  accounts     Account[]
  sessions     Session[]
  notifications Notification[] // User can receive notifications related to habits

  @@map("users")
}

model Habit {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  name        String
  description String?
  frequency   Frequency @default(DAILY)
  startDate   DateTime @default(now())
  endDate     DateTime? // Habit can have an end date
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  records     Record[]
  goal        Int? // Target value for the habit (e.g., drink 8 glasses of water)
  unit        String? // Unit of measurement for the goal (e.g., glasses)
  timeOfDay   TimeOfDay? @default(ANY) //When should the habit be completed (morning, evening, anytime)
  reminder    Reminder? //Each habit can have a reminder
  notifications Notification[] //Habit can trigger notifications

  @@map("habits")
}

model Record {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  date      DateTime @db.Date // Date when the habit was tracked
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  completed Boolean @default(false)
  value     Float? //Actual value tracked (e.g., 6 glasses of water) - relevant if Habit has a goal

  @@unique([habitId, date]) // Ensure only one record per habit per day

  @@map("records")
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum TimeOfDay {
  MORNING
  AFTERNOON
  EVENING
  ANY
}

//Added model for reminders
model Reminder {
  id        String    @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  time      DateTime // Time of day for the reminder
  habitId   String @unique
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  enabled   Boolean  @default(true)
  @@map("reminders")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model Notification {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  habitId String
  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
  message   String
  read      Boolean @default(false)
  @@map("notifications")
}